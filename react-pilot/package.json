{
  "name": "react-pilot",
  "private": true,
  "version": "0.1.0",
  "description": "Manta metadata pilot and desktop shell for NOAA UxS workflows.",
  "author": "CPCayson",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "VITE_OPEN=0 node scripts/run-netlify-dev.mjs",
    "dev:vite": "vite",
    "dev:with-api-proxy": "API_PROXY_TARGET=http://127.0.0.1:8888 vite",
    "dev:netlify": "VITE_OPEN=0 node scripts/run-netlify-dev.mjs",
    "build": "vite build",
    "desktop:dev": "ELECTRON_START_URL=http://127.0.0.1:8888 electron .",
    "desktop:start": "npm run build && electron .",
    "desktop:pack": "npm run build && electron-builder --dir",
    "desktop:dist": "npm run build && electron-builder",
    "publish": "npm run build && node scripts/publish-dist.mjs",
    "publish:zip": "npm run publish && node scripts/package-share.mjs",
    "lint": "eslint .",
    "audit:xml": "node scripts/audit-xml.mjs",
    "audit:manta-samples": "node scripts/audit-manta-end-user-samples.mjs",
    "verify:manta-pipeline": "node scripts/audit-manta-end-user-samples.mjs --verify-pipeline",
    "verify:manta-eut-perfect": "node scripts/audit-manta-end-user-samples.mjs --verify-pipeline --fail-if-lenient-errors",
    "verify:manta-eut-strict": "node scripts/audit-manta-end-user-samples.mjs --verify-pipeline --fail-if-lenient-errors --fail-if-strict-errors",
    "verify:manta-eut-catalog": "node scripts/audit-manta-end-user-samples.mjs --verify-pipeline --fail-if-lenient-errors --fail-if-catalog-errors",
    "compare:navy-preview": "node scripts/compare-navy-import-preview.mjs",
    "audit:uxs-depth": "node scripts/audit-navy-xml-depth.mjs --write-reports --eut-samples",
    "audit:navy-depth": "node scripts/audit-navy-xml-depth.mjs --write-reports --navy-only --include-fixtures",
    "audit:uxs-depth:full": "node scripts/audit-navy-xml-depth.mjs --write-reports --eut-samples && node scripts/audit-navy-xml-depth.mjs --write-reports --navy-only --include-fixtures",
    "pilot:import-coverage": "node scripts/pilot-state-import-coverage.mjs",
    "validate:xml": "node scripts/validate-xml.mjs",
    "validate:preview-sample": "node scripts/validate-preview-sample.mjs",
    "validate:bedi": "node scripts/validate-bedi-ncei-xml.mjs",
    "validate:manta-samples-comet": "node scripts/validate-all-manta-samples-comet.mjs",
    "test:bedi": "node scripts/test-bedi-xml-parsers.mjs",
    "test:uxs-navy": "node scripts/test-uxs-navy-xml-parsers.mjs",
    "verify:pilot": "npm run lint && npm run build && npm run test:bedi && npm run test:uxs-navy && node scripts/verify-pilot.mjs",
    "docs:placeholders": "node scripts/extract-ncei-uxs-placeholder-xlsx.mjs > docs/uxs-ncei-placeholder-xlsx-crosswalk.md",
    "docs:mission-validation-rules": "node scripts/export-mission-validation-rules.mjs",
    "repomix": "repomix",
    "repomix:critical": "repomix --config repomix.critical.config.json",
    "schemas:noaa-public": "node scripts/mirror-noaa-schemas-public.mjs",
    "swarm:validate": "node scripts/swarm/validate-rules-csv.mjs",
    "swarm:sync": "node scripts/swarm/sync-rules-from-matrices.mjs",
    "swarm:compile": "node scripts/swarm/compile-rules.mjs",
    "swarm:qa": "node scripts/swarm/check-rules-quality.mjs",
    "swarm:pull:comet": "node scripts/swarm/pull-comet-xml-fixtures.mjs",
    "swarm:export:comet:missions": "node scripts/swarm/export-comet-mission-forms.mjs",
    "swarm:search:comet": "node scripts/swarm/search-comet-similar.mjs",
    "swarm:regress": "node scripts/swarm/regress-mission-validity.mjs",
    "swarm:regress:roundtrip": "node scripts/swarm/regress-mission-validity.mjs --include-roundtrip --allow-write",
    "swarm:api:coverage": "node scripts/swarm/check-comet-api-coverage.mjs",
    "swarm:audit:import": "node scripts/swarm/audit-mission-import.mjs",
    "swarm:preview-xml": "node scripts/swarm/verify-xml-preview-format.mjs --eut-samples",
    "swarm:audit": "node scripts/swarm/audit-repo.mjs",
    "swarm:audit:rules": "node scripts/swarm/audit-repo.mjs --skip-regress",
    "swarm:loop": "npm run swarm:all && npm run swarm:regress && npm run swarm:api:coverage",
    "swarm:condition:demo": "node scripts/swarm/evaluate-condition.mjs",
    "swarm:all": "npm run swarm:sync && npm run swarm:validate && npm run swarm:compile && npm run swarm:qa",
    "batch:waf:audit": "node scripts/batch/waf-audit.mjs",
    "batch:uuid:audit": "node scripts/batch/uuid-audit.mjs",
    "batch:nodd:plan": "node scripts/batch/nodd-plan.mjs",
    "batch:osdd:plan": "node scripts/batch/osdd-plan.mjs",
    "batch:report": "node scripts/batch/batch-report.mjs",
    "batch:all": "npm run batch:waf:audit && npm run batch:uuid:audit && npm run batch:report",
    "bedi:link-template": "node scripts/bedi/link-resolve-template.mjs",
    "bedi:scrape-docucomp": "node scripts/bedi/scrape-docucomp-refs.mjs",
    "postinstall": "patch-package",
    "preview": "vite preview"
  },
  "build": {
    "appId": "gov.noaa.uxs.manta",
    "productName": "Manta Metadata Desktop",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    }
  },
  "dependencies": {
    "@genkit-ai/ai": "^1.34.0",
    "@genkit-ai/google-genai": "^1.34.0",
    "@genkit-ai/googleai": "^1.28.0",
    "@neondatabase/serverless": "^1.1.0",
    "fflate": "^0.8.2",
    "genkit": "^1.34.0",
    "leaflet": "^1.9.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "xmllint-wasm": "^5.2.0",
    "z": "^1.0.9"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@xmldom/xmldom": "^0.8.13",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "patch-package": "^8.0.1",
    "repomix": "^1.14.0",
    "vite": "^8.0.10"
  }
}
