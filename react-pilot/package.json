{
  "name": "react-pilot",
  "private": true,
  "version": "0.0.0",
  "description": "Manta metadata pilot and desktop shell for NOAA UxS workflows.",
  "author": "CPCayson",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "desktop:dev": "ELECTRON_START_URL=http://127.0.0.1:5173 electron .",
    "desktop:start": "npm run build && electron .",
    "desktop:pack": "npm run build && electron-builder --dir",
    "desktop:dist": "npm run build && electron-builder",
    "publish": "npm run build && node scripts/publish-dist.mjs",
    "publish:zip": "npm run publish && node scripts/package-share.mjs",
    "lint": "eslint .",
    "validate:xml": "node scripts/validate-xml.mjs",
    "validate:bedi": "node scripts/validate-bedi-ncei-xml.mjs",
    "test:bedi": "node scripts/test-bedi-xml-parsers.mjs",
    "verify:pilot": "npm run lint && npm run build && npm run test:bedi && node scripts/verify-pilot.mjs",
    "docs:placeholders": "node scripts/extract-ncei-uxs-placeholder-xlsx.mjs > docs/uxs-ncei-placeholder-xlsx-crosswalk.md",
    "preview": "vite preview"
  },
  "build": {
    "appId": "gov.noaa.uxs.manta",
    "productName": "Manta Metadata Desktop",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    }
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "fflate": "^0.8.2",
    "leaflet": "^1.9.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@xmldom/xmldom": "^0.8.13",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "vite": "^8.0.10"
  }
}
