# Copy to `.env.local` for local overrides (optional).
# Pilot talks to same-origin `/api/db` via Netlify Functions — use `netlify dev` from
# `react-pilot/` so `/api/db` resolves (see docs/DEPLOYMENT.md).

# Optional: shown in About / diagnostics when set at build time.
# VITE_APP_VERSION=0.0.0-dev

# When "true", hides named readiness + certification goal rows in the left rail (Draft, ISO-ready,
# CoMET, DocuComp chips, etc.). Lenient / Strict / Catalog mode pills stay; the issue list is unchanged.
# Use while fixing import parsers so the rail is not dominated by downstream goals.
# VITE_HIDE_READINESS_BUNDLES=true

# CoMET REST API proxy (server-side only — never prefix with VITE_)
# Base URL for the CoMET API (no trailing slash).
# Auth is JSESSIONID cookie-based (form login), NOT a Bearer token.
COMET_BASE_URL=https://data.noaa.gov/cedit
# JSESSIONID from an active CoMET session cookie.
# How to get it:
#   Option A: Call POST /api/comet-proxy?action=login with your NOAA credentials.
#   Option B: Log in at https://data.noaa.gov/cedit, open DevTools → Application
#             → Cookies → copy the JSESSIONID value.
# Sessions expire after inactivity — refresh as needed.
COMET_SESSION_ID=

# NOAA metaserver legacy validation endpoint (optional; used by action=metaservValidate)
METASERVER_BASE_URL=https://data.noaa.gov/metaserver
# If unset, the proxy falls back to COMET_SESSION_ID.
METASERVER_SESSION_ID=

# Gemini intent parsing (server-side only, consumed by netlify/functions/manta-intent.mjs)
GEMINI_API_KEY=
# Optional: override model used by netlify/functions/manta-intent.mjs
GEMINI_MODEL=gemini-2.5-flash
